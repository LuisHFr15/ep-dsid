AWS_REGION=us-east-1

# Fila SQS de comandos de fallback (JOIN/LEAVE) produzidos pelo hub.
# Recomendado configurar na fila uma redrive policy (maxReceiveCount + DLQ):
# o worker acka mensagens malformadas para nao reprocessa-las, mas uma DLQ
# garante que comandos problematicos fiquem para inspecao em vez de sumirem.
SQS_QUEUE_URL=

# Tempo de long-poll do ReceiveMessage, em segundos (0-20).
SQS_WAIT_TIME_SECONDS=20

# Diretorio local (EBS) onde o WebTorrent baixa/semeia os arquivos.
SEED_DIR=./data

# Credenciais resolvidas pela cadeia padrao do SDK.
# Use AWS_PROFILE ou as chaves abaixo.
AWS_PROFILE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
