{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "src/domain",
    "src/application",
    "src/infrastructure",
    "src/testing",
    "src/main/electron-container.ts",
    "src/infrastructure/torrent/webtorrent.d.ts"
  ],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
