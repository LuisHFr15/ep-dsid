PORT=3000

AWS_REGION=us-east-1
DYNAMO_TABLE=ep-dsid-hub
# Deixe vazio para usar a AWS real. Preencha apenas para um endpoint customizado.
DYNAMO_ENDPOINT=

# Credenciais resolvidas pela cadeia padrao do SDK.
# Use AWS_PROFILE ou as chaves abaixo.
AWS_PROFILE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

JWT_SECRET=troque-este-segredo
JWT_EXPIRES_IN=1h
BCRYPT_ROUNDS=10

# Fila SQS de comandos de fallback (JOIN/LEAVE). Se vazio, os comandos
# apenas sao logados e nada e enviado para a AWS.
SQS_QUEUE_URL=
# Intervalo do avaliador periodico de fallback, em milissegundos.
FALLBACK_SWEEP_INTERVAL_MS=15000
# Intervalo do flush da presenca (RAM -> DynamoDB), em milissegundos.
PRESENCE_FLUSH_INTERVAL_MS=10000
