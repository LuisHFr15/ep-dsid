PORT=3000

AWS_REGION=us-east-1
DYNAMO_TABLE=ep-dsid-hub
# Deixe vazio para usar a AWS real. Preencha apenas para um endpoint customizado.
DYNAMO_ENDPOINT=

# Credenciais resolvidas pela cadeia padrao do SDK.
# Use AWS_PROFILE ou as chaves abaixo.
AWS_PROFILE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

JWT_SECRET=troque-este-segredo
JWT_EXPIRES_IN=1h
BCRYPT_ROUNDS=10
